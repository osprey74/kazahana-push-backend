# API認証（kazahanaアプリにビルド時埋め込み）
API_SECRET=your-secret-key-here

# APNs（iOS）
APNS_KEY_ID=XXXXXXXXXX
APNS_TEAM_ID=XXXXXXXXXX
APNS_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
APNS_BUNDLE_ID=com.osprey74.kazahana
APNS_PRODUCTION=false

# FCM（Android）
FCM_PROJECT_ID=kazahana-android
FCM_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}

# Jetstream
JETSTREAM_URL=wss://jetstream2.us-east.bsky.network/subscribe

# SQLite
DATABASE_PATH=/data/kazahana-push.db

# ログ
LOG_LEVEL=info
